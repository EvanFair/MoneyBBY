# OpenRouter API Key for Llama-3/Qwen inference
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: If you prefer to use OpenAI directly
OPENAI_API_KEY=your_openai_api_key_here

# LLM model to use (defaulting to a high-quality, fast model)
LLM_MODEL=meta-llama/llama-3-70b-instruct:free

# Anthropic API Key (used first if set)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PiAPI key for FLUX.1 image generation
